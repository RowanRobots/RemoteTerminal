{
  # 本地环境默认关闭自动 HTTPS，避免自签证书与端口占用干扰联调。
  auto_https off
}

# 生产建议：先用 `caddy hash-password --plaintext '你的密码'` 生成哈希后替换。
# 下方示例用户名 admin，密码 password（请务必修改）。
http://127.0.0.1:8081 {
  basicauth {
    admin $2a$14$Zkx19XLiW6VYouLHR5NmfOFU0z2GTNmpkT/5qqR7hx4IjWJPDhjvG
  }

  @api path /api/*
  handle @api {
    reverse_proxy 127.0.0.1:8080
  }

  @term path /term/*
  handle @term {
    reverse_proxy 127.0.0.1:8080
  }

  # 前端静态文件（Vite build 输出）
  handle {
    root * /home/aro/code/RemoteTerminal/frontend/dist
    try_files {path} /index.html
    file_server
  }
}
