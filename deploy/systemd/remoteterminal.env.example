# Generated production env is published to .prod-runtime/current/config/remoteterminal.env
HOME=$HOME
BIND_ADDR=127.0.0.1:8080
DATA_DIR=$HOME/code/RemoteTerminal/.prod-runtime/current/var/data
ALLOWED_ROOT=$HOME/code
PUBLIC_BASE_URL=http://127.0.0.1:8080
FRONTEND_DIST=$HOME/code/RemoteTerminal/.prod-runtime/current/frontend/dist
TTYD_PORT_MIN=12000
TTYD_PORT_MAX=12999
TTYD_ROOT=$HOME/.local/opt/ttyd/pkg
# CODEX_BIN_DIR is optional; install_systemd_service.sh will auto-detect it when possible.
# CODEX_BIN_DIR=$HOME/.nvm/versions/node/<version>/bin
RUST_LOG=info,sqlx=warn
